{
  "name": "antigravity-restores-conversation",
  "displayName": "Antigravity Restores Conversation",
  "description": "Restore lost conversation history and missing workspaces for Antigravity IDE",
  "version": "1.0.0",
  "main": "./dist/cli.js",
  "bin": "dist/cli.js",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "build": "esbuild src/cli/index.ts --bundle --outfile=dist/cli.js --platform=node --format=cjs",
    "dev": "npm run build && node --no-warnings dist/cli.js",
    "compile": "tsc -p ./",
    "build:exe": "node scripts/build-exe.mjs"
  },
  "dependencies": {
    "@clack/prompts": "^0.7.0",
    "chalk": "^4.1.2",
    "glob": "^10.0.0",
    "picocolors": "^1.0.0",
    "protobufjs": "^7.4.0"
  },
  "devDependencies": {
    "@types/node": "^22.5.0",
    "esbuild": "^0.23.0",
    "typescript": "^5.2.2"
  }
}
